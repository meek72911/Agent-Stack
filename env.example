# ============================================================
# AgentStack -- Environment Variables
# Copy to .env and fill in required values
# ============================================================

# -- App -------------------------------------------------------
NODE_ENV=development                          # development | staging | production
APP_URL=http://localhost:3000                 # Dashboard URL (used for CORS, redirects)
API_URL=http://localhost:8000                 # FastAPI backend URL

# -- Supabase --------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=                     # Supabase project URL (required)
NEXT_PUBLIC_SUPABASE_ANON_KEY=                # Supabase anonymous/public key (required)
SUPABASE_SERVICE_ROLE_KEY=                    # Supabase service role key (required)
SUPABASE_JWT_SECRET=                          # JWT secret from Supabase dashboard (required)
SUPABASE_DB_URL=                              # Direct Postgres connection string (required)

# -- Database (local dev via Docker) ---------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agentstack
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentstack

# -- Redis / Upstash -------------------------------------------
UPSTASH_REDIS_REST_URL=                       # Upstash Redis REST URL (required in prod)
UPSTASH_REDIS_REST_TOKEN=                     # Upstash Redis REST token (required in prod)
REDIS_URL=redis://localhost:6379              # Local Redis URL for dev

# -- Stripe Billing --------------------------------------------
STRIPE_SECRET_KEY=                            # Stripe secret key (required)
STRIPE_PUBLISHABLE_KEY=                       # Stripe publishable key (required)
STRIPE_WEBHOOK_SECRET=                        # Stripe webhook signing secret (required)
STRIPE_PRICE_PRO_MONTHLY=                     # Stripe Price ID for Pro monthly ($29/mo)
STRIPE_PRICE_PRO_ANNUAL=                      # Stripe Price ID for Pro annual ($290/yr)
STRIPE_PRICE_TEAM_MONTHLY=                    # Stripe Price ID for Team monthly ($79/mo)
STRIPE_PRICE_TEAM_ANNUAL=                     # Stripe Price ID for Team annual ($790/yr)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=           # Exposed to client

# -- Encryption (BYOK Keys) ------------------------------------
ENCRYPTION_KEY=                               # Fernet key for BYOK API key encryption (required)

# -- LiteLLM ---------------------------------------------------
LITELLM_MASTER_KEY=                           # LiteLLM proxy master key (optional)
LITELLM_LOG_LEVEL=INFO                        # LiteLLM log level

# -- OAuth Providers -------------------------------------------
GOOGLE_CLIENT_ID=                             # Google OAuth client ID (optional)
GOOGLE_CLIENT_SECRET=                         # Google OAuth client secret (optional)
GITHUB_CLIENT_ID=                             # GitHub OAuth client ID (optional)
GITHUB_CLIENT_SECRET=                         # GitHub OAuth client secret (optional)

# -- Error Tracking & Analytics --------------------------------
SENTRY_DSN=                                   # Sentry DSN (optional)
NEXT_PUBLIC_SENTRY_DSN=                       # Sentry DSN for client (optional)
NEXT_PUBLIC_POSTHOG_KEY=                      # PostHog project API key (optional)
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -- Email -----------------------------------------------------
RESEND_API_KEY=                               # Resend API key (optional)
EMAIL_FROM=noreply@agentstack.dev             # Default from address

# -- FastAPI Backend -------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true
LOG_LEVEL=info                                # debug | info | warning | error
CORS_ORIGINS=http://localhost:3000            # Comma-separated allowed origins

# -- Railway ---------------------------------------------------
RAILWAY_ENVIRONMENT=                          # Set by Railway automatically
PORT=                                         # Set by Railway automatically
